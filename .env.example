# --- Telegram MTProto (https://my.telegram.org → API development tools) ---
TG_API_ID=
TG_API_HASH=
TG_PHONE=+380XXXXXXXXX
TG_SESSION_NAME=telegram_watcher

# --- Claude CLI ---
# Requires `claude` CLI installed and authenticated (Claude Pro subscription).
# No ANTHROPIC_API_KEY is used.
CLAUDE_MODEL=claude-haiku-4-5

# --- Storage ---
DB_PATH=data/telegram_watcher.db

# --- Dashboard ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
# Bearer token for the dashboard. Leave empty for the default loopback bind.
# REQUIRED if DASHBOARD_HOST is anything other than 127.0.0.1 / localhost / ::1
# (the supervisor refuses to start otherwise). Generate one with:
#   openssl rand -hex 32
DASHBOARD_TOKEN=

# --- Daily digest cron ---
DIGEST_CRON_HOUR=8
LOCAL_TZ=Europe/Kyiv

# --- Initial groups to watch (one-shot seed on first run) ---
# Format: "<link_or_@username>|<topic_hint>;<link_or_@username>|<topic_hint>;..."
# The topic_hint is appended to the relevance prompt for that group.
# Examples:
#   @ai_news_ua|ai
#   https://t.me/c/1234567890/4350|gamedev
WATCHED_GROUPS_INIT=

# --- Behaviour ---
# Max messages pulled from each group per daily scan
MAX_MSGS_PER_GROUP=500
# How many parallel Claude calls (default 4)
CLASSIFY_CONCURRENCY=4
# Classify messages immediately as they arrive (true) or only in the daily cron (false)
REALTIME_AI_FILTER=true
# Don't send to Claude messages shorter than this many characters
MIN_GROUP_TEXT_LEN=30
